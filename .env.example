# Data and build settings
RAGFORYL_DATA_DIR=./data
RAGFORYL_EXTRACTION_MODE=auto
RAGFORYL_CHUNK_SIZE=1200
RAGFORYL_CHUNK_OVERLAP=120
RAGFORYL_MAX_UPLOAD_MB=30

# Optional OpenAI-compatible model. Leave blank to use the offline extractor.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_TIMEOUT_SECONDS=90
